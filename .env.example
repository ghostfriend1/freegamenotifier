# =============================================
# Free Game Notifier v6.0 Configuration
# Copy this file to .env and fill in your values.
# =============================================

# ---------- Required ----------
DISCORD_TOKEN=your_discord_bot_token_here
CHANNEL_ID=123456789012345678

# ---------- Recommended ----------
# Your Discord user ID — unlocks owner commands (/forcecheck, /fgpanel).
OWNER_ID=987654321098765432

# Role to ping on a new free game (0 = ping @here instead).
# For the ping to fire, either make the role "mentionable" OR give the bot the
# "Mention @everyone, @here, and All Roles" permission. The /fgpanel opt-in
# button also needs the bot to have "Manage Roles", with its own role placed
# ABOVE this role in Server Settings -> Roles.
PING_ROLE_ID=0

# How often to check, in minutes (recommended 10-30; lower = more API load).
CHECK_INTERVAL_MINUTES=15

# NOTE: PING_ROLE_ID, MIN_WORTH, EXPIRY_REMINDER_HOURS, INCLUDE_LOOT and
# INCLUDE_BETA below are just DEFAULTS — you can change them live (no redeploy)
# with the /fgconfig command, and those overrides persist in the database.
# The /fgclear command additionally needs the bot to have "Manage Messages".

# Epic Games Store region.
EPIC_LOCALE=en-US
EPIC_COUNTRY=US

# ---------- Optional features ----------
# Only announce games worth at least this much (USD). 0 = announce everything.
# Games with an unknown price are always announced.
MIN_WORTH=0

# Re-ping a "last chance!" reminder this many hours before a giveaway ends.
# 0 = disable reminders.
EXPIRY_REMINDER_HOURS=6

# Also announce free in-game loot / key giveaways (true/false).
INCLUDE_LOOT=false

# Also announce free beta-access giveaways (true/false).
INCLUDE_BETA=false

# Seconds to wait between posts (keeps Discord rate limits happy).
POST_DELAY_SECONDS=1.5

# ---------- Claim & Share ----------
# Show the "📢 Post my win to the channel" button inside the share kit (true/false).
ALLOW_PUBLIC_SHARE=true

# Link included in generated share text — point this at your bot's invite or
# landing page for organic promotion.
SHARE_PROMO_URL=https://github.com/ghostfriend1/freegamenotifier

# ---------- Advanced ----------
# Single server ID for INSTANT slash-command sync (great while testing).
# Leave 0 for a global sync (can take up to ~1h to appear).
GUILD_ID=0

# On a BRAND-NEW database, "true" silently records whatever is already free
# instead of dumping every current freebie at once; only NEW games get announced
# afterward. Set "false" to announce everything free on the very first run.
QUIET_SEED=true

# Where the dedup database lives. Keep the default so existing history is reused.
# On Docker/Railway, mount a volume here so it survives restarts.
DB_FILE=free_games_v3.db

# =============================================
# How to get the IDs (enable Developer Mode in Discord first):
#   DISCORD_TOKEN -> Discord Developer Portal -> Your Bot -> Reset/Copy Token
#   CHANNEL_ID    -> right-click the channel  -> Copy Channel ID
#   OWNER_ID      -> right-click yourself      -> Copy User ID
#   PING_ROLE_ID  -> right-click the role      -> Copy Role ID
#   GUILD_ID      -> right-click the server     -> Copy Server ID
# Never commit your real .env (it's already gitignored).
# =============================================
